# Copy this file to /etc/travel/travel.env on the server and edit values.

APP_DIR=/opt/travel
SERVER_NAME=YOUR_SERVER_PUBLIC_IP

SERVER_PORT=9090

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=db_travel
MYSQL_USERNAME=travel
MYSQL_PASSWORD=Travel@123456
MYSQL_ROOT_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

FILE_UPLOAD_DIR=/opt/travel/files
FILE_BASE_URL=http://YOUR_SERVER_PUBLIC_IP
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_PUBLIC_IP

ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=http://YOUR_SERVER_PUBLIC_IP/front/orders
