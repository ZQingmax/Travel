[Unit]
Description=Travel Spring Boot Backend
After=network.target mysql.service redis-server.service

[Service]
Type=simple
EnvironmentFile=/etc/travel/travel.env
WorkingDirectory=${APP_DIR}/springboot
ExecStart=/usr/bin/java -Xms256m -Xmx768m -jar ${APP_DIR}/springboot/target/springboot-0.0.1-SNAPSHOT.jar
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
