<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mingde.mapper.RoutesMapper">

    <select id="selectAll" resultType="com.mingde.entity.Routes">
        select * from `routes`
        <where>
            <if test="name != null"> and name like concat('%', #{name}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectPage" resultType="com.mingde.entity.Routes">
        select * from `routes`
        <where>
            <if test="query != null and query.name != null"> and name like concat('%', #{query.name}, '%')</if>
        </where>
        order by id desc
    </select>

</mapper>