<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mingde.mapper.ArticleMapper">

    <select id="selectAll" resultType="com.mingde.entity.Article">
        select * from `article`
        <where>
            <if test="title != null"> and title like concat('%', #{title}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectPage" resultType="com.mingde.entity.Article">
        select * from `article`
        <where>
            <if test="query != null and query.title != null"> and title like concat('%', #{query.title}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectRecommend" resultType="com.mingde.entity.Article">
        select * from `article` order by read_count desc limit 3
    </select>

</mapper>