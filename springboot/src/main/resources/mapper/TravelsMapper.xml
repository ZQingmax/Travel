<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mingde.mapper.TravelsMapper">

    <select id="selectAll" resultType="com.mingde.entity.Travels">
        select
        t.*,
        u.name AS userName
        from travels t
        left join user u on t.user_id = u.id
        <where>
            <if test="title != null"> and t.title like concat('%', #{title}, '%')</if>
            <if test="status != null"> and t.status = #{status}</if>
            <if test="userId != null"> and t.user_id = #{userId}</if>
        </where>
        <if test="sort == 'hot'">
            order by t.read_count desc
        </if>
        <if test="sort == 'new' or sort == null">
            order by t.id desc
        </if>
    </select>

    <delete id="deleteById">
        delete from `travels`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.mingde.entity.Travels" keyProperty="id" useGeneratedKeys="true">
        insert into `travels`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="title != null">title,</if>
            <if test="cover != null">cover,</if>
            <if test="descr != null">descr,</if>
            <if test="content != null">content,</if>
            <if test="userId != null">user_id,</if>
            <if test="time != null">time,</if>
            <if test="readCount != null">read_count,</if>
            <if test="startDate != null">start_date,</if>
            <if test="money != null">money,</if>
            <if test="days != null">days,</if>
            <if test="location != null">location,</if>
            <if test="status != null">status,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="title != null">#{title},</if>
            <if test="cover != null">#{cover},</if>
            <if test="descr != null">#{descr},</if>
            <if test="content != null">#{content},</if>
            <if test="userId != null">#{userId},</if>
            <if test="time != null">#{time},</if>
            <if test="readCount != null">#{readCount},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="money != null">#{money},</if>
            <if test="days != null">#{days},</if>
            <if test="location != null">#{location},</if>
            <if test="status != null">#{status},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.mingde.entity.Travels">
        update `travels`
        <set>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="cover != null">
                cover = #{cover},
            </if>
            <if test="descr != null">
                descr = #{descr},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
            <if test="readCount != null">
                read_count = #{readCount},
            </if>
            <if test="startDate != null">
                start_date = #{startDate},
            </if>
            <if test="money != null">
                money = #{money},
            </if>
            <if test="days != null">
                days = #{days},
            </if>
            <if test="location != null">
                location = #{location},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>